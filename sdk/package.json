{
  "name": "@obligo/sdk",
  "version": "0.1.0",
  "description": "Typed TypeScript client for Obligo — a permissionless clearing house for loyalty liabilities on Solana.",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "prove": "node examples/prove.ts",
    "smoke": "node examples/smoke.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "solana",
    "token-2022",
    "transfer-hook",
    "loyalty",
    "obligo"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "@solana/spl-token": "^0.4.15"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
